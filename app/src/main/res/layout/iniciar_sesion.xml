<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#F8F9FA"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="24dp"
        android:maxWidth="340dp">

        <!-- Círculo logo -->
        <ImageView
            android:id="@+id/imgLogo"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="40dp"
            android:background="@drawable/circle_mask"
            android:src="@drawable/ic_launcher_foreground"
            android:scaleType="centerCrop"
            android:padding="4dp" />

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="HabiTrack"
            android:textStyle="bold"
            android:textSize="28sp"
            android:layout_marginTop="24dp"
            android:textColor="#000000" />

        <!-- Subtítulo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Construye mejores hábitos, día a día."
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="32dp" />

        <!-- Botones tabs -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="32dp">

            <Button
                android:id="@+id/btnLogin"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:text="Iniciar Sesión"
                android:textSize="14sp"
                android:background="@drawable/button_filled"
                android:textColor="#FFFFFF"
                android:layout_marginEnd="12dp" />

            <Button
                android:id="@+id/btnRegister"
                android:layout_width="130dp"
                android:layout_height="40dp"
                android:text="Registrarse"
                android:textSize="14sp"
                android:background="@drawable/button_outline"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- Texto "¿No tienes cuenta?" -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿No tienes cuenta? Pulsa registrarse"
            android:textSize="16sp"
            android:textColor="#666666"
            android:layout_marginBottom="32dp" />

        <!-- Email -->
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="ejemplo@gmail.com"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="16dp"
            android:background="@drawable/edittext_bg"
            android:padding="16dp"
            android:textSize="16sp"/>

        <!-- Password -->
        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:hint="Mín 8 caracteres, 1 mayúscula"
            android:inputType="textPassword"
            android:layout_marginBottom="32dp"
            android:background="@drawable/edittext_bg"
            android:padding="16dp"
            android:textSize="16sp"/>

        <!-- Botón principal -->
        <Button
            android:id="@+id/btnMainAction"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Iniciar Sesión"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="@drawable/button_filled"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="40dp" />

    </LinearLayout>
</LinearLayout>
