<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Cabecera -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/fondoCabecera"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="#DDDDDD"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="70dp"
                    android:layout_marginBottom="20dp"
                    android:text="NUEVO HÁBITO"
                    android:textAlignment="center"
                    android:textColor="#000000"
                    android:textSize="24sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#000000" />
        </LinearLayout>

        <!-- Campo TÍTULO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginBottom="24dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Título del hábito *"
                android:textColor="#666666"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:inputType="textMultiLine"
                android:maxLines="3"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Campo DESCRIPCIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginBottom="24dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descripción"
                android:textColor="#666666"
                android:textSize="14sp" />

            <EditText
                android:id="@+id/etSubtitulo"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:background="@null"
                android:inputType="textCapWords"
                android:textSize="18sp" />
        </LinearLayout>

        <!-- COLOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:layout_marginBottom="24dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Color"
                android:textColor="#666666"
                android:textSize="14sp" />

            <LinearLayout
                android:id="@+id/seleccionColores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/colorGris"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="#DDDDDD"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/colorNaranja"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="#FAE5D3"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/colorVerde"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="#D4EFDF"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/colorAzul"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_marginEnd="8dp"
                    android:layout_weight="1"
                    android:background="#D1E8FF"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal" />

                <LinearLayout
                    android:id="@+id/colorMorado"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="#EBDEF0"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="horizontal" />
            </LinearLayout>
        </LinearLayout>

        <!-- RECORDATORIO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:orientation="horizontal"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Recordatorio"
                android:textColor="#666666"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/switchRecordatorio"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />
        </LinearLayout>

        <!-- FRECUENCIA + DÍAS PERSONALIZADOS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Frecuencia"
                android:textColor="#666666"
                android:textSize="14sp" />

            <RadioGroup
                android:id="@+id/rgFrecuencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbDiario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diariamente"
                    android:checked="true" />

                <RadioButton
                    android:id="@+id/rbPersonalizado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Personalizado" />
            </RadioGroup>

            <LinearLayout
                android:id="@+id/layoutDiasPersonalizados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:gravity="center"
                android:visibility="gone">

                <CheckBox
                    android:id="@+id/chkLunes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="L"
                    android:textSize="14sp"
                    android:textColor="#000000" />

                <CheckBox
                    android:id="@+id/chkMartes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="M"
                    android:textSize="14sp"
                    android:textColor="#000000" />

                <CheckBox
                    android:id="@+id/chkMiercoles"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="X"
                    android:textSize="14sp"
                    android:textColor="#000000" />

                <CheckBox
                    android:id="@+id/chkJueves"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="J"
                    android:textSize="14sp"
                    android:textColor="#000000" />

                <CheckBox
                    android:id="@+id/chkViernes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="V"
                    android:textSize="14sp"
                    android:textColor="#000000" />

                <CheckBox
                    android:id="@+id/chkSabado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="S"
                    android:textSize="14sp"
                    android:textColor="#000000" />

                <CheckBox
                    android:id="@+id/chkDomingo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D"
                    android:textSize="14sp"
                    android:textColor="#000000" />
            </LinearLayout>
        </LinearLayout>

        <!-- Botones en la misma fila -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline_grey"
                android:text="Guardar hábito"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="18sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="8dp"
                android:layout_height="0dp" />

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:background="@drawable/button_outline"
                android:text="Cancelar"
                android:textAllCaps="false"
                android:textColor="#000000"
                android:textSize="16sp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
