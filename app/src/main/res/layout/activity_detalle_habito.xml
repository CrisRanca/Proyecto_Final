<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CABECERA -->
        <LinearLayout
            android:id="@+id/cabeceraDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#DDDDDD"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvTituloDetalle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Hábito"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#000000" />

        <!-- SUBTÍTULO -->
        <TextView
            android:id="@+id/tvSubtituloDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Descripción"
            android:textColor="#333333"
            android:textSize="16sp" />

        <!-- FRECUENCIA -->
        <TextView
            android:id="@+id/tvFrecuenciaDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Frecuencia"
            android:textColor="#333333"
            android:textSize="16sp" />

        <!-- NOTIFICACIONES -->
        <TextView
            android:id="@+id/tvNotificacionesDetalle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp"
            android:text="Notificaciones"
            android:textColor="#333333"
            android:textSize="16sp" />

        <!-- ESTADÍSTICAS -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Ánimo promedio:"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvAnimoPromedio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="—"
                android:textSize="18sp"
                android:textColor="#333333"
                android:layout_marginBottom="16dp" />

            <TextView
                android:text="Total veces realizado:"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvTotalVeces"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="18sp"
                android:textColor="#333333"
                android:layout_marginBottom="16dp" />

            <TextView
                android:text="Porcentaje de cumplimiento:"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvPorcentaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="0%"
                android:textSize="18sp"
                android:textColor="#333333" />
        </LinearLayout>

        <!-- CALENDARIO -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Calendario:"
            android:textSize="18sp"
            android:textColor="#000000"
            android:padding="16dp" />

        <GridLayout
            android:id="@+id/gridCalendario"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="7"
            android:padding="16dp" />

        <!-- BOTÓN REGISTRAR -->
        <Button
            android:id="@+id/btnRegistrarSeguimiento"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_margin="16dp"
            android:text="Registrar seguimiento"
            android:textColor="#000000"
            android:background="@drawable/button_outline_grey"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
