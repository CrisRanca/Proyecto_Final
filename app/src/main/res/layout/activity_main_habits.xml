<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- CABECERA (color del usuario) -->
    <LinearLayout
        android:id="@+id/cabeceraPrincipal"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar circular -->
        <ImageView
            android:id="@+id/imgAvatar"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:scaleType="centerCrop"
            android:background="@drawable/circle_mask"
            android:clipToOutline="true"
            android:layout_marginEnd="16dp" />

        <!-- Nombre, nivel y puntos -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvNombreUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Usuario"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvNivel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nivel: 0"
                android:textSize="16sp"
                android:textColor="#000000" />

            <TextView
                android:id="@+id/tvPuntos"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Puntos: 0"
                android:textSize="16sp"
                android:textColor="#000000" />
        </LinearLayout>

        <!-- Botón menú -->
        <TextView
            android:id="@+id/btnMenu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⋮"
            android:textSize="28sp"
            android:padding="8dp"
            android:textColor="#000000" />
    </LinearLayout>

    <!-- LÍNEA NEGRA JUSTO DEBAJO DE LA CABECERA -->
    <View
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:background="#000000" />

    <!-- BOTONES HOY / MIS HÁBITOS / AÑADIR -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:padding="12dp">

        <Button
            android:id="@+id/btnHoy"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="Hoy"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="@drawable/button_outline" />

        <Button
            android:id="@+id/btnMisHabitos"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:text="Mis hábitos"
            android:textStyle="bold"
            android:textColor="#000000"
            android:background="@drawable/button_outline" />
    </LinearLayout>

    <!-- CONTENEDOR DE HÁBITOS -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/contenedorHabitos"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp" />
    </ScrollView>

    <Button
        android:id="@+id/btnAñadirHabito"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Añadir hábito"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_margin="16dp"
        android:background="@drawable/button_outline"
        android:textColor="#000000"/>

</LinearLayout>
