<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- CABECERA -->
        <LinearLayout
            android:id="@+id/fondoCabecera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#DDDDDD"
            android:gravity="center">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="60dp"
                android:layout_marginBottom="40dp"
                android:text="EDITAR HÁBITO"
                android:textAlignment="center"
                android:textColor="#000000"
                android:textSize="24sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- LÍNEA NEGRA -->
        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#000000" />

        <!-- TÍTULO -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Título del hábito *"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etTitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- DESCRIPCIÓN -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Descripción"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <EditText
                android:id="@+id/etSubtitulo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@null"
                android:textSize="16sp"/>
        </LinearLayout>

        <!-- COLOR -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Color"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:id="@+id/seleccionColores"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <LinearLayout
                    android:id="@+id/colorGris"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/color_base"
                    android:tag="#DDDDDD"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:id="@+id/colorNaranja"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/color_base"
                    android:tag="#FAE5D3"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:id="@+id/colorVerde"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/color_base"
                    android:tag="#D4EFDF"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:id="@+id/colorAzul"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/color_base"
                    android:tag="#D1E8FF"
                    android:layout_marginEnd="8dp"/>

                <LinearLayout
                    android:id="@+id/colorMorado"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1"
                    android:background="@drawable/color_base"
                    android:tag="#EBDEF0"/>
            </LinearLayout>
        </LinearLayout>

        <!-- FRECUENCIA -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:text="Frecuencia"
                android:textColor="#666666"
                android:textSize="14sp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <RadioGroup
                android:id="@+id/rgFrecuencia"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="8dp">

                <RadioButton
                    android:id="@+id/rbDiario"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Diariamente"/>

                <RadioButton
                    android:id="@+id/rbPersonalizado"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="Personalizado"/>
            </RadioGroup>

            <LinearLayout
                android:id="@+id/layoutDiasPersonalizados"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="12dp"
                android:visibility="gone">

                <CheckBox android:id="@+id/chkLunes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="L"/>
                <CheckBox android:id="@+id/chkMartes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="M"/>
                <CheckBox android:id="@+id/chkMiercoles" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="X"/>
                <CheckBox android:id="@+id/chkJueves" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="J"/>
                <CheckBox android:id="@+id/chkViernes" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="V"/>
                <CheckBox android:id="@+id/chkSabado" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="S"/>
                <CheckBox android:id="@+id/chkDomingo" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="D"/>
            </LinearLayout>
        </LinearLayout>

        <!-- BOTONES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="16dp"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnGuardar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="GUARDAR CAMBIOS"
                android:textColor="#000000"
                android:textStyle="bold"
                android:background="@drawable/button_base"/>

            <Space android:layout_width="8dp" android:layout_height="0dp"/>

            <Button
                android:id="@+id/btnCancelar"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:layout_weight="1"
                android:text="Cancelar"
                android:textColor="#000000"
                android:background="@drawable/button_base"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
